{
  "manifest_version": 3,
  "key": "",
  "name": "Waifu2x Image Upscaler",
  "description": "Upscale and replace web images in place with local waifu2x-ncnn-vulkan.",
  "version": "0.8.3",
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "nativeMessaging",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Waifu2x Image Upscaler",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
